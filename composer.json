{
  "name": "sendexa/sdk",
  "description": "Official Sendexa PHP SDK — SMS, OTP, WhatsApp, Email, Voice, and Webhooks",
  "version": "0.1.0",
  "type": "library",
  "license": "MIT",
  "authors": [
    { "name": "Sendexa Limited", "homepage": "https://sendexa.co" }
  ],
  "keywords": ["sendexa", "sms", "otp", "whatsapp", "messaging", "ghana", "api", "sdk"],
  "homepage": "https://docs.sendexa.co",
  "require": {
    "php": ">=8.1",
    "ext-curl": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "Sendexa\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Sendexa\\Tests\\": "tests/"
    }
  },
  "support": {
    "source": "https://github.com/sendexa/sendexa-php",
    "docs": "https://docs.sendexa.co/sdks/php"
  }
}
